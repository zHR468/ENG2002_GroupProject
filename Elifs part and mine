from menu import fixNum
def get_number():
    """
    docstring needed here
    this part asks the user to enter a number in form of a and b and
    validates that a is an integer and b can be converted into an integer
    """
    #loop runs until correct a and b are entered
    while True:
        try:
            a = int(input("Enter the integer part (a): "))
            b = input("Enter the fractional part (b): ")
            int(b) #validate that b is a number

            #if a is positive, take away the negative sign infront of b if b was entered as a negative
            if a>0:
                b = b.lstrip('-')
                
            return fixNum(a,b)
        except Exception as e:
            print(f"Invalid input, and error occured {e}. Enter numbers only")

def save_sum(num):
    """
    docstring needed here
    creates a file and writes the sum in it to enable user add new numbers to this sum
    """
    f = open("sum.txt","w")
    #writes the a and b parts of the calculated sum into the file
    f.write(f"{num.a} {num.b}")
    f.close

def get_sum():
    """
    docstring needed here
    """
    try:
        f = open("sum.txt","r")
        #assigns val
        a,b = f.read().split()
        f.close
    
        return fixNum(int(a),b)
    except FileNotFound:
        return fixNum(0,'0')

def menu():
    """
    docstring needed here
    """
    while True:
        print("""
        1. Add numbers
        2.get power
        3. quit
        """)
        choice = input("enter your choice")
        if choice == '1':
            print("enter the first one")
            n1 = get_number()
            #allows the user to continue adding to the previous sums
            while True:
                print("enter the second one")
                n2 = get_number()

                result = n1.add(n2)
                print(f"Result is {result} with a = {result.a} and b = {result.b}")
                save_sum(result)
                cont = input("Continue adding to this sum? (y/n)")
                if cont.lower() !='y':
                    break
                n1 = get_sum()
                

        elif choice == '2':
            num = get_number()
            while True:
                try:
                    n = int(input("Enter the power"))
                    break
                except ValueError:
                    print("Invalid input. Enter a number")
                result = num.power(n)
                print(f"The result is {result}")
            

        elif choice == '3':
            break

        else:
            continue
            